# ============================================================
# CCIS — AuraBank | Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Groq API ---
# Found in: https://console.groq.com/keys
# Used for: AI complaint classification, sentiment analysis, summaries (Phase 5)
GROQ_API_KEY=your-groq-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
